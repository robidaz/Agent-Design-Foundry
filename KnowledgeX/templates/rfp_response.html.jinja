<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>RFP/RFI Response — {{ artifact.engagement_id }}</title>
<style>
  @page {
    size: Letter;
    margin: 18mm 16mm 20mm 16mm;
    @bottom-right {
      content: "Page " counter(page) " of " counter(pages);
      font-size: 9pt;
      color: #666;
    }
    @bottom-left {
      content: "KnowledgeX RFP/RFI Draft — {{ artifact.engagement_id }}";
      font-size: 9pt;
      color: #666;
    }
  }

  body {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 10pt;
    line-height: 1.4;
    color: #1f2328;
  }

  h1 { font-size: 18pt; margin: 0 0 4pt 0; }
  h2 { font-size: 13pt; margin: 14pt 0 6pt 0; border-bottom: 1px solid #d0d7de; padding-bottom: 3pt; }
  h3 { font-size: 11pt; margin: 12pt 0 4pt 0; }

  .meta {
    color: #57606a;
    font-size: 9pt;
    margin-bottom: 12pt;
  }
  .meta span { margin-right: 14pt; }

  .notice {
    padding: 8pt 10pt;
    border-radius: 4pt;
    margin: 8pt 0;
    page-break-inside: avoid;
  }
  .notice .label {
    font-weight: 600;
    text-transform: uppercase;
    font-size: 8pt;
    letter-spacing: 0.5pt;
    display: block;
    margin-bottom: 2pt;
  }
  .error    { background: #ffebe9; border-left: 3pt solid #cf222e; color: #82071e; }
  .warning  { background: #fff8c5; border-left: 3pt solid #d4a72c; color: #633c01; }
  .info     { background: #ddf4ff; border-left: 3pt solid #0969da; color: #0a3069; }

  table { width: 100%; border-collapse: collapse; }
  th, td {
    border: 1px solid #d0d7de;
    padding: 5pt 7pt;
    text-align: left;
    font-size: 9.5pt;
  }
  th { background: #f6f8fa; font-weight: 600; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }

  .question {
    page-break-inside: avoid;
    margin: 10pt 0 14pt 0;
    border: 1pt solid #d0d7de;
    border-radius: 4pt;
    padding: 8pt 10pt;
  }
  .qheader {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 4pt;
  }
  .qid {
    font-weight: 700;
    font-size: 11pt;
  }
  .qtext {
    font-style: italic;
    color: #1f2328;
    margin-bottom: 6pt;
  }

  .band {
    display: inline-block;
    padding: 1pt 7pt;
    border-radius: 10pt;
    font-size: 8pt;
    font-weight: 700;
    letter-spacing: 0.5pt;
  }
  .band-HIGH      { background: #dafbe1; color: #1a7f37; }
  .band-MEDIUM    { background: #fff8c5; color: #633c01; }
  .band-LOW       { background: #ffebe9; color: #82071e; }
  .band-NO_SOURCE { background: #ffebe9; color: #82071e; }
  .band-CONFLICT  { background: #ffebe9; color: #82071e; }

  .review-flag {
    margin-left: 6pt;
    background: #d4a72c;
    color: #1f2328;
    padding: 1pt 5pt;
    border-radius: 8pt;
    font-size: 7.5pt;
    font-weight: 700;
    letter-spacing: 0.4pt;
  }

  .draft  { margin: 4pt 0 6pt 0; }
  .citations {
    font-size: 8.5pt;
    color: #57606a;
    margin-top: 4pt;
  }
  .citations code {
    background: #f6f8fa;
    padding: 1pt 4pt;
    border-radius: 3pt;
    font-size: 8.5pt;
  }

  .footer-status {
    margin-top: 14pt;
    padding-top: 8pt;
    border-top: 1pt solid #d0d7de;
    font-size: 9pt;
  }
  .status-needs-review { color: #cf222e; font-weight: 600; }

  .watermark {
    position: fixed;
    top: 38%;
    left: 0;
    right: 0;
    text-align: center;
    transform: rotate(-35deg);
    font-size: 56pt;
    font-weight: 900;
    letter-spacing: 4pt;
    color: #b0b0b0;
    opacity: 0.20;
    white-space: nowrap;
    pointer-events: none;
  }
</style>
</head>
<body>

<div class="watermark">SME REVIEW DRAFT</div>

<h1>RFP / RFI Response — Draft</h1>
<div class="meta">
  <span><strong>Engagement:</strong> {{ artifact.engagement_id }}</span>
  <span><strong>Generated:</strong> {{ artifact.generated_at.strftime("%Y-%m-%d %H:%M UTC") }}</span>
</div>

<h2>Summary</h2>
{% set counts = artifact.band_counts() %}
<table>
  <thead>
    <tr><th>Band</th><th class="num">Count</th></tr>
  </thead>
  <tbody>
    <tr><td><span class="band band-HIGH">HIGH</span></td><td class="num">{{ counts.HIGH }}</td></tr>
    <tr><td><span class="band band-MEDIUM">MEDIUM</span> · SME review</td><td class="num">{{ counts.MEDIUM }}</td></tr>
    <tr><td><span class="band band-LOW">LOW</span> · escalated</td><td class="num">{{ counts.LOW }}</td></tr>
    <tr><td><span class="band band-NO_SOURCE">NO-SOURCE</span> · escalated</td><td class="num">{{ counts.NO_SOURCE }}</td></tr>
    <tr><td><span class="band band-CONFLICT">CONFLICT</span> · escalated</td><td class="num">{{ counts.CONFLICT }}</td></tr>
    <tr><td><strong>Total</strong></td><td class="num"><strong>{{ artifact.questions | length }}</strong></td></tr>
  </tbody>
</table>

{% if artifact.escalation_queue %}
<div class="notice warning">
  <span class="label">Escalation queue</span>
  {{ artifact.escalation_queue | length }} item(s) routed to SME. See the standalone
  <code>escalation_{{ artifact.engagement_id }}.md</code> document and the per-question entries below.
</div>
{% endif %}

<h2>Per-Question Responses</h2>

{% for q in artifact.questions %}
<div class="question">
  <div class="qheader">
    <span class="qid">{{ q.question_id }}</span>
    <span>
      <span class="band band-{{ q.confidence_band }}">{{ q.confidence_band }}</span>
      {% if q.confidence_band == "MEDIUM" %}<span class="review-flag">REVIEW</span>{% endif %}
    </span>
  </div>
  <div class="qtext">{{ q.question_text }}</div>

  {% if q.draft_text %}
    <div class="draft">{{ q.draft_text }}</div>
  {% elif q.conflict_versions %}
    <div class="notice error">
      <span class="label">Conflicting versions — SME resolves</span>
      <ul style="margin: 4pt 0 0 14pt; padding: 0;">
        {% for v in q.conflict_versions %}<li>{{ v }}</li>{% endfor %}
      </ul>
    </div>
  {% else %}
    <div class="notice error">
      <span class="label">No draft — escalated</span>
      {{ q.escalation_reason or "Routed to SME escalation queue." }}
    </div>
  {% endif %}

  {% if q.citations %}
    <div class="citations">
      <strong>Citations:</strong>
      {% for c in q.citations %}
        <code>{{ c.source_doc }}#{{ c.chunk_id }}</code>
        ({{ "%.2f"|format(c.similarity_score) }}){% if not loop.last %} ·{% endif %}
      {% endfor %}
    </div>
  {% endif %}
</div>
{% endfor %}

<div class="footer-status">
  Status:
  {% if artifact.requires_human_review %}
    <span class="status-needs-review">Requires SME review before customer delivery.</span>
  {% endif %}
</div>

</body>
</html>
