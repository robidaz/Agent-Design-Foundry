{
  // -----------------------------
  // Global Editor Behavior
  // -----------------------------
  "editor.formatOnSave": true,
  "editor.detectIndentation": false,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 100,
  "editor.minimap.enabled": false,
  "editor.trimAutoWhitespace": true,
  "editor.rulers": [
    88
  ],
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  // -----------------------------
  // File Cleanliness
  // -----------------------------
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/.pytest_cache": true
  },
  // -----------------------------
  // Search
  // -----------------------------
  "search.exclude": {
    "**/.git": true,
    "**/__pycache__": true
  },
  // -----------------------------
  // Language-Specific
  // -----------------------------
  "[python]": {
    "editor.tabSize": 4
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  // -----------------------------
  // Markdown Formatting
  // -----------------------------
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "other": false
    }
  },
  "markdown.extension.toc.levels": "2..4",
  "markdown.extension.toc.updateOnSave": true,
  "markdown.extension.orderedList.marker": "one",
  "markdownlint.run": "onSave",
  "markdownlint.configFile": ".vscode/.markdownlint.jsonc",
  "editor.codeActionsOnSave": {
    "source.fixAll.markdownlint": "explicit"
  },
  // -----------------------------
  // JSON Formatting
  // -----------------------------
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  // -----------------------------
  // YAML Formatting + Validation
  // -----------------------------
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "yaml.validate": true,
  "yaml.format.enable": true,
  // -----------------------------
  // cSpell Configuration
  // -----------------------------
  "cSpell.checkOnlyEnabledFileTypes": true,
  "cSpell.enabledFileTypes": {
    "markdown": true,
    "python": false,
    "yaml": false,
    "json": false,
    "html": false,
    "toml": false
  },
  "cSpell.ignorePaths": [
    "**/scripts/**",
    "**/node_modules/**",
    "**/.venv/**",
    "**/*.html",
    "**/formatting/cspell.json",
    "**/.gitignore",
    "**/.gitattributes",
    "**/.gitmodules",
    "**/.vscode/**"
  ],
  // -----------------------------
  // Python
  // -----------------------------
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  // -----------------------------
  // GitLens
  // -----------------------------
  "gitlens.currentLine.enabled": false,
  "gitlens.codeLens.enabled": false,
  // -----------------------------
  // Copilot
  // -----------------------------
  "github.copilot.enable": {
    "*": true,
    "markdown": true,
    "plaintext": false
  },
  // -----------------------------
  // PDF Viewer
  // -----------------------------
  "pdf.preview.autoReload": true,
  // -----------------------------
  // Markdown Table + Inline Editor
  // -----------------------------
  "markdowntable.formatOnSave": true,
  "markdowntable.ignoreCodeblock": true,
  "markdownInlineEditor.emojis.enabled": true,
  "markdownInlineEditor.math.enabled": true,
  // -----------------------------
  // PDF Export
  // -----------------------------
  "markdown-pdf.convertOnSave": false,
  "markdown-pdf.header.template": "<div></div>",
  "markdown-pdf.scale": 0.75,
  "markdown-pdf.format": "A4",
  "markdown-pdf.margin.top": "15mm",
  "markdown-pdf.margin.bottom": "15mm",
  "markdown-pdf.margin.right": "15mm",
  "markdown-pdf.margin.left": "15mm",
  "markdown-pdf.styles": [
    ".vscode/markdown-pdf.css"
  ],
  "chat.tools.terminal.autoApprove": {
    "&": true
  },
  // -----------------------------
  // Workbench
  // -----------------------------
  "open-in-browser.default": "firefox",
  "terminal.integrated.defaultProfile.linux": "bash",
  "workbench.editor.enablePreview": false,
  "workbench.startupEditor": "none",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  //------------------------------
  // Run on Save
  // -----------------------------
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": "masc_(data|message|localization)_dictionary\\.yaml$",
        "cmd": "\"${workspaceFolder}\\.venv\\Scripts\\python.exe\" \"${workspaceFolder}\\scripts\\generate-yaml-dictionary-html.py\" \"${file}\""
      },
      {
        "match": "MASC Localization\\.xlsx$",
        "cmd": "\"${workspaceFolder}\\.venv\\Scripts\\python.exe\" \"${workspaceFolder}\\scripts\\generate-yaml-dictionary-html.py\" \"${file}\""
      }
    ]
  },
  "cSpell.words": [
    "ADLC",
    "anonymization",
    "Dynamix",
    "Ollama",
    "pydantic",
    "referenceability",
    "Robida",
    "SDLC",
    "Syncfusion",
    "Syncfusion's",
    "templatable"
  ]
}
